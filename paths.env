# paths.env — environment-specific paths.
#
# Source this from any shell script in the repo (e.g. `source ../paths.env`
# from inside `code/`). Python scripts read the same variables via
# `os.environ.get(...)` with sensible fallbacks. Edit these three lines for
# your environment; nothing else in the repo should need path edits.

# Repository root — directory containing this file.
export REPO_ROOT=/dss/dssmcmlfs01/pn25pu/pn25pu-dss-0000/adhakimi/LLM_PT_interpret

# Large-data filesystem holding model snapshots, raw outputs, and postprocessed
# outputs. Subdirectories used:
#   $DATA_ROOT/revisions_temp/                       — HuggingFace snapshot cache
#   $DATA_ROOT/new_outputs/                          — raw per-checkpoint pickles (step 2)
#   $DATA_ROOT/new_processed_outputs/                — postprocessed pickles (step 3)
#   $DATA_ROOT/neuron_outputs/                       — raw outputs with neuron_contributions (for step 4 plots)
export DATA_ROOT=/dss/dssfs04/lwp-dss-0002/pn25ho/pn25ho-dss-0001/di35pop

# Conda env path. The SLURM scripts will `conda activate "$CONDA_ENV"`.
export CONDA_ENV=/dss/dssmcmlfs01/pn25pu/pn25pu-dss-0000/adhakimi/LLM_PT_interpret2/conda_env/llmtt
